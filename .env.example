# --- Database (Neon Postgres) ---
# Get this from your Neon project dashboard. Use the POOLED connection string.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# --- Auth.js (NextAuth v5) ---
# Generate with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# The base URL of your app. Leave as localhost for dev.
NEXTAUTH_URL="http://localhost:3000"

# Public version (used by client-side billing redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Google OAuth ---
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Groq (AI provider) ---
# Create at https://console.groq.com/keys
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"

# --- Stripe (billing) ---
# Create at https://dashboard.stripe.com/apikeys
# Use the TEST keys during development.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs from your Stripe Products dashboard
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_YEARLY="price_..."
STRIPE_PRICE_AGENCY_MONTHLY="price_..."
STRIPE_PRICE_AGENCY_YEARLY="price_..."

# --- Resend (transactional email) ---
# Create at https://resend.com/api-keys
RESEND_API_KEY="re_..."
# From-address — must be on a verified domain. During dev you can use the
# sandbox: onboarding@resend.dev
EMAIL_FROM="Proponiq <hello@proponiq.com>"
